AEGIS_ARTIFACT_DIR=./artifacts
AEGIS_OCR_ENABLED=true
AEGIS_OCR_COMMAND=tesseract
AEGIS_COMMAND_TIMEOUT_MS=5000
AEGIS_SCREENSHOT_BACKEND=auto
AEGIS_INPUT_BACKEND=auto
AEGIS_SAFE_MODE=false
AEGIS_ALLOWED_LAUNCH_COMMANDS=firefox,google-chrome,chromium,code,gedit,gnome-terminal,xdg-open
AEGIS_LOG_LEVEL=info
AEGIS_MAX_SCREENSHOTS_PER_MINUTE=30
AEGIS_MAX_INPUT_SEQUENCE_STEPS=256
AEGIS_CONFIG_PATH=
